# Force LF on shell scripts so they execute on Linux even if edited on Windows
*.sh           text eol=lf
*.bash         text eol=lf
Dockerfile     text eol=lf
*.Dockerfile   text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.conf         text eol=lf
*.toml         text eol=lf
*.ini          text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
