# =============================================================================
# UniFi ThreatFlow Hub — environment template
# Copy to .env and run scripts/init.sh to populate auto-generated secrets.
# Never commit the real .env file.
# =============================================================================

# ---- Branding ---------------------------------------------------------------
APP_NAME="UniFi Threatflow Hub for AmSpec"
APP_DOMAIN=threatflow.amspec.group
APP_ENV=production            # development | production
LOG_LEVEL=info                # debug | info | warning | error

# ---- Mock data --------------------------------------------------------------
# When true, collectors generate fake events and dashboards work without real UniFi devices.
MOCK_DATA=true

# ---- Admin bootstrap --------------------------------------------------------
ADMIN_EMAIL=diederik.vantienen@amspecgroup.com
# Leave empty + run scripts/create-admin.sh to auto-generate and PRINT to terminal.
ADMIN_PASSWORD=

# ---- Secrets (auto-generated by scripts/init.sh) ----------------------------
# 32+ chars, used to sign JWTs / sessions
SESSION_SECRET=
JWT_SECRET=
# 44-char Fernet key for branch credential encryption at rest
FERNET_KEY=

# ---- PostgreSQL (control-plane) --------------------------------------------
POSTGRES_USER=threatflow
POSTGRES_PASSWORD=
POSTGRES_DB=threatflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- ClickHouse (analytics) -------------------------------------------------
CLICKHOUSE_USER=threatflow
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=threatflow
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Retention defaults (days). All overridable via Settings UI later.
CH_TTL_RAW_FLOWS_DAYS=90
CH_TTL_RAW_THREATS_DAYS=180
CH_TTL_ROLLUP_1M_DAYS=180
CH_TTL_ROLLUP_5M_DAYS=365
CH_TTL_ROLLUP_15M_DAYS=365
CH_TTL_ROLLUP_1H_DAYS=730
CH_TTL_ROLLUP_1D_DAYS=1825

# Insert tuning
CH_BATCH_SIZE=5000
CH_FLUSH_INTERVAL_MS=2000
CH_INSERT_RETRIES=3

# ---- Redis ------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Collector --------------------------------------------------------------
COLLECTOR_INTERVAL_SECONDS=30
COLLECTOR_MAX_CONCURRENT=10
COLLECTOR_TIMEOUT_SECONDS=10
COLLECTOR_RETRIES=2

# ---- Backend (FastAPI) ------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=2
# CORS — keep tight in production
CORS_ALLOW_ORIGINS=https://threatflow.amspec.group

# ---- Frontend (Next.js) -----------------------------------------------------
NEXT_PUBLIC_APP_NAME="UniFi Threatflow Hub for AmSpec"
NEXT_PUBLIC_API_BASE=/api
# When deployed behind nginx the browser uses /api on the same origin.
# For local dev hit http://localhost:18091/api directly.

# ---- Host port bindings (loopback only — DO NOT publish on 0.0.0.0) ---------
# These are how nginx (or local dev) reaches the containers.
HOST_FRONTEND_PORT=18090
HOST_BACKEND_PORT=18091
